package veristore

import "github.com/verifone/veristoretools3/templates/layouts"

// ImportData holds the state for the import page.
type ImportData struct {
	InProgress   bool
	RequestDate  string
	Progress     string
	LastComplete bool
	LastFilename string
	Errors       []string
}

// ImportPage renders the terminal import page with status tracking.
templ ImportPage(page layouts.PageData, data ImportData) {
	@layouts.Base(page) {
		<div class="row mb-3">
			<div class="col">
				if data.InProgress {
					<div class="alert alert-info" style="font-size: 1.1rem;">
						Import is on process, please wait until finish!
						<br/>
						File: { data.RequestDate }
						<br/>
						Progress: { data.Progress }
					</div>
					<a href="/veristore/import-format" class="btn btn-primary">
						<i class="fas fa-download"></i> Download Format
					</a>
					<a href="/veristore/import" class="btn btn-success ml-2">
						<i class="fas fa-sync-alt"></i> Refresh
					</a>
					<a href="/veristore/importreset" class="btn btn-warning ml-2" onclick="return confirm('Reset the import process?')">
						<i class="fas fa-undo"></i> Reset
					</a>
				} else if data.LastComplete {
					<div class="alert alert-success" style="font-size: 1.1rem;">
						Last import completed: { data.LastFilename } ({ data.Progress })
					</div>
					<div class="row">
						<div class="col-md-8 offset-md-2">
							<div class="card card-primary">
								<div class="card-header">
									<h3 class="card-title">Import Terminals</h3>
									<div class="card-tools">
										<a href="/veristore/terminal" class="btn btn-sm btn-default">
											<i class="fas fa-arrow-left"></i> Back to List
										</a>
									</div>
								</div>
								<form method="POST" action="/veristore/import" enctype="multipart/form-data">
									<div class="card-body">
										<div class="form-group">
											<label for="file">Select Excel File (.xlsx)</label>
											<div class="input-group">
												<div class="custom-file">
													<input type="file" class="custom-file-input" id="file" name="file" accept=".xlsx,.xls"/>
													<label class="custom-file-label" for="file">Choose file</label>
												</div>
											</div>
											<small class="form-text text-muted">
												Upload an Excel file with terminal data.
												<a href="/veristore/import-format">Download template</a>
											</small>
										</div>
									</div>
									<div class="card-footer">
										<button type="submit" class="btn btn-primary">
											<i class="fas fa-file-import"></i> Import
										</button>
										<a href="/veristore/terminal" class="btn btn-default ml-2">Cancel</a>
									</div>
								</form>
							</div>
						</div>
					</div>
				} else {
					<div class="row">
						<div class="col-md-8 offset-md-2">
							<div class="card card-primary">
								<div class="card-header">
									<h3 class="card-title">Import Terminals</h3>
									<div class="card-tools">
										<a href="/veristore/terminal" class="btn btn-sm btn-default">
											<i class="fas fa-arrow-left"></i> Back to List
										</a>
									</div>
								</div>
								<form method="POST" action="/veristore/import" enctype="multipart/form-data">
									<div class="card-body">
										if len(data.Errors) > 0 {
											<div class="alert alert-danger alert-dismissible fade show" role="alert">
												<ul class="mb-0">
													for _, err := range data.Errors {
														<li>{ err }</li>
													}
												</ul>
												<button type="button" class="close" data-dismiss="alert" aria-label="Close">
													<span aria-hidden="true">&times;</span>
												</button>
											</div>
										}
										<div class="form-group">
											<label for="file">Select Excel File (.xlsx)</label>
											<div class="input-group">
												<div class="custom-file">
													<input type="file" class="custom-file-input" id="file" name="file" accept=".xlsx,.xls"/>
													<label class="custom-file-label" for="file">Choose file</label>
												</div>
											</div>
											<small class="form-text text-muted">
												Upload an Excel file with terminal data.
												<a href="/veristore/import-format">Download template</a>
											</small>
										</div>
									</div>
									<div class="card-footer">
										<button type="submit" class="btn btn-primary">
											<i class="fas fa-file-import"></i> Import
										</button>
										<a href="/veristore/terminal" class="btn btn-default ml-2">Cancel</a>
									</div>
								</form>
							</div>
						</div>
					</div>
				}
			</div>
		</div>
		<script>
			document.querySelector('.custom-file-input')?.addEventListener('change', function(e) {
				var fileName = e.target.files[0]?.name || 'Choose file';
				e.target.nextElementSibling.textContent = fileName;
			});
		</script>
	}
}
