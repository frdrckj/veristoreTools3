				</div>
			</div>
		</div>
	</div>
}

// defaultDashboard renders the default dashboard for users without specific roles.
templ defaultDashboard(page layouts.PageData) {
	<div class="jumbotron text-center">
		if page.AppLogo != "" {
			<h1>
				<img style="width:100px;" alt="" src={ "/static/img/" + page.AppLogo }/>
				<strong>{ page.AppName }</strong>
			</h1>
		} else {
			<h1><strong>{ page.AppName }</strong></h1>
		}
	</div>
}
